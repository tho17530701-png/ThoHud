local function CreateMenuToggle(text, pos, default, activeColor, callback)
    local btn = Instance.new("TextButton")
    btn.Parent = MainMenu
    btn.Size = UDim2.new(0, 180, 0, 30)
    btn.Position = pos
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 13
    
    local state = default
    local function updateText()
        btn.Text = text .. ": " .. (state and "BẬT" or "TẤT")
        btn.TextColor3 = state and activeColor or Color3.fromRGB(255, 100, 100)
    end
    
    updateText()
    btn.MouseButton1Click:Connect(function()
        state = not state
        updateText()
        callback(state)
    end)
    
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, 5)
    c.Parent = btn
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
end

