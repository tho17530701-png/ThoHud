    ToggleButton.Position = UDim2.new(0.05, 0, 0.2, 0)
    ToggleButton.Size = UDim2.new(0, 55, 0, 55)
    ToggleButton.Text = "MENU"
    ToggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    ToggleButton.TextSize = 11
    ToggleButton.Font = Enum.Font.SourceSansBold

    local ButtonCorner = Instance.new("UICorner")
    ButtonCorner.CornerRadius = UDim.new(0, 12)
    ButtonCorner.Parent = ToggleButton

    local ButtonStroke = Instance.new("UIStroke")
    ButtonStroke.Color = Color3.fromRGB(0, 255, 150)
    ButtonStroke.Thickness = 1.5
    ButtonStroke.Parent = ToggleButton

    MainMenu = Instance.new("Frame")
    MainMenu.Parent = ScreenGui
    MainMenu.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    MainMenu.Position = UDim2.new(0.12, 0, 0.2, 0)
    MainMenu.Size = UDim2.new(0, 220, 0, 320)
    MainMenu.Visible = false

    local MenuCorner = Instance.new("UICorner")
    MenuCorner.CornerRadius = UDim.new(0, 8)
    MenuCorner.Parent = MainMenu

    local MenuTitle = Instance.new("TextLabel")
    MenuTitle.Parent = MainMenu
    MenuTitle.Size = UDim2.new(1, 0, 0, 35)
    MenuTitle.Text = "Tho dz - Anti-Crash V3"
    MenuTitle.TextColor3 = Color3.fromRGB(0, 255, 150)
    MenuTitle.TextSize = 15
    MenuTitle.Font = Enum.Font.SourceSansBold
    MenuTitle.BackgroundTransparency = 1

    local function CreateMenuToggle(text, pos, configKey, activeColor)
        local btn = Instance.new("TextButton")
        btn.Parent = MainMenu
        btn.Size = UDim2.new(0, 180, 0, 30)
        btn.Position = pos
        btn.Font = Enum.Font.SourceSansBold
        btn.TextSize = 12
        
        local function updateText()
            local state = _G.ESP_Config[configKey]
            btn.Text = text .. ": " .. (state and "ON" or "OFF")
            btn.TextColor3 = state and activeColor or Color3.fromRGB(255, 100, 100)
        end
        
        updateText()
        btn.MouseButton1Click:Connect(function()
            _G.ESP_Config[configKey] = not _G.ESP_Config[configKey]
            updateText()
        end)
        
        local c = Instance.new("UICorner")
        c.CornerRadius = UDim.new(0, 5)
        c.Parent = btn
        btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    end

    CreateMenuToggle("Player Body (Full)", UDim2.new(0, 20, 0, 45), "Player_Box", Color3.fromRGB(0, 255, 150))
    CreateMenuToggle("Player Name & Distance", UDim2.new(0, 20, 0, 85), "Player_Name", Color3.fromRGB(0, 255, 150))
    CreateMenuToggle("NPC Body (Full)", UDim2.new(0, 20, 0, 135), "NPC_Box", Color3.fromRGB(255, 200, 0))
    CreateMenuToggle("NPC Name & Distance", UDim2.new(0, 20, 0, 175), "NPC_Name", Color3.fromRGB(255, 200, 0))
    CreateMenuToggle("Item Box", UDim2.new(0, 20, 0, 225), "Item_Box", Color3.fromRGB(255, 0, 255))
    CreateMenuToggle("Item Name & Distance", UDim2.new(0, 20, 0, 265), "Item_Name", Color3.fromRGB(255, 0, 255))

    -- Draggable functionality
    local function MakeDraggable(obj)
        local dragging, dragInput, dragStart, startPos
        obj.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true; dragStart = input.Position; startPos = obj.Position
                input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
            end
        end)
        obj.InputChanged:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end end)
        UserInputService.InputChanged:Connect(function(input)
            if input == dragInput and dragging then
                local delta = input.Position - dragStart
                obj.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            end
        end)
    end
    MakeDraggable(ToggleButton)
    MakeDraggable(MainMenu)

    ToggleButton.MouseButton1Click:Connect(function() MainMenu.Visible = not MainMenu.Visible end)
end

BuildUI()

-- Entity Analyzer Mechanics
local function IsNPC(model)
    if not model:IsA("Model") or Players:GetPlayerFromCharacter(model) then return false end
    return model:FindFirstChildOfClass("Humanoid") and model:FindFirstChild("HumanoidRootPart")
end

local function AnalyzeNPC(model)
    local hum = model:FindFirstChildOfClass("Humanoid")
    if not hum or hum.WalkSpeed <= 1 or model:FindFirstChild("ClickDetector") then return "Interaction", Color3.fromRGB(255, 255, 255) end
    if model:FindFirstChildOfClass("Tool") or model:FindFirstChild("Enemy") or model:FindFirstChild("Monster") or model.Name:lower():find("zombie") then
        return "Enemy", Color3.fromRGB(255, 50, 50)
    end
    return "Friendly", Color3.fromRGB(0, 150, 255)
end

-- Efficient Item Cache Mapping to completely eliminate CPU drops
local function CheckItem(obj)
    if not obj:IsA("BasePart") or obj.Parent:IsA("Accessory") then return end
    local nameLower = obj.Name:lower()
    local pNameLower = obj.Parent and obj.Parent.Name:lower() or ""
    
    for _, ign in ipairs(IgnoreKeywords) do
        if nameLower:find(ign) or pNameLower:find(ign) then return end
    end

    for _, kw in ipairs(ValidItemKeywords) do
        if nameLower:find(kw) or pNameLower:find(kw) then
            ItemCache[obj] = true
            return
        end
    end
end

local function FullMapScan()
    table.clear(ItemCache)
    for _, obj in ipairs(workspace:GetDescendants()) do
        CheckItem(obj)
    end
end
FullMapScan()

