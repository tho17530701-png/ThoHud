for _, obj in ipairs(workspace:GetDescendants()) do
    if IsNPC(obj) then
        task.spawn(ApplyNPC_ESP, obj)
    else
        local target, name = CheckAndGetItemRoot(obj)
        if target then task.spawn(ApplyItemESP, target, name) end
    end
end

workspace.DescendantAdded:Connect(function(obj)
    task.delay(0.5, function()
        if IsNPC(obj) then
            ApplyNPC_ESP(obj)
        else
            local target, name = CheckAndGetItemRoot(obj)
            if target then ApplyItemESP(target, name) end
        end
    end)
end)

game:GetService("RunService").Heartbeat:Connect(function()
    local localHrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local hl = player.Character:FindFirstChild("P_Highlight")
            if hl then hl.Enabled = Player_Box_Enabled end
            local hrp = player.Character:FindFirstChild("HumanoidRootPart")
            local gui = hrp and hrp:FindFirstChild("P_Gui")
            if gui then
                gui.Enabled = Player_Name_Enabled
                if Player_Name_Enabled and localHrp and hrp then
                    local dist = (hrp.Position - localHrp.Position).Magnitude
                    gui.TextLabel.Text = player.Name .. " [" .. math.floor(dist) .. "m]"
                end
            end
        end
    end

    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj:FindFirstChild("NPC_Highlight") then
            local hl = obj:FindFirstChild("NPC_Highlight")
            hl.Enabled = NPC_Box_Enabled
            local hrp = obj:FindFirstChild("HumanoidRootPart")
            local gui = hrp and hrp:FindFirstChild("NPC_Gui")
            if gui then
                gui.Enabled = NPC_Name_Enabled
                if NPC_Name_Enabled and localHrp and hrp then
                    local dist = (hrp.Position - localHrp.Position).Magnitude
                    local npcType, npcColor = AnalyzeNPC(obj)
                    hl.OutlineColor = npcColor
                    gui.TextLabel.TextColor3 = npcColor
                    gui.TextLabel.Text = obj.Name .. " [" .. npcType .. "] [" .. math.floor(dist) .. "m]"
                end
            end
        elseif obj:IsA("BasePart") and obj:FindFirstChild("Item_Highlight") then
            local hl = obj:FindFirstChild("Item_Highlight")
            hl.Enabled = Item_Box_Enabled
            local gui = obj:FindFirstChild("Item_Gui")
            if gui then
                gui.Enabled = Item_Name_Enabled
                if Item_Name_Enabled and localHrp then
                    local dist = (obj.Position - localHrp.Position).Magnitude
                    local baseName = obj.Parent:IsA("Model") and obj.Parent.Name or obj.Name
                    local vnName = GetVietnameseName(baseName)
                    gui.TextLabel.Text = vnName .. " [" .. math.floor(dist) .. "m]"
                end
            end
        end
    end
end)
