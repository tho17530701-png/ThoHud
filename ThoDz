local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local function IsNPC(model)
    if Players:GetPlayerFromCharacter(model) then return false end
    if model:IsA("Model") and model:FindFirstChildOfClass("Humanoid") and model:FindFirstChild("HumanoidRootPart") then
        return true
    end
    return false
end

local function AnalyzeNPC(model)
    local humanoid = model:FindFirstChildOfClass("Humanoid")
    if not humanoid then return "Nhiệm Vụ/Shop", Color3.fromRGB(255, 255, 255) end

    if humanoid.WalkSpeed <= 1 or humanoid.MaxSlopeAngle == 0 or model:FindFirstChild("ClickDetector") or model:FindFirstChildOfClass("Dialog") then
        return "Tương Tác", Color3.fromRGB(255, 255, 255)
    end

    local hasWeapon = model:FindFirstChildOfClass("Tool") or model:FindFirstChild("Weapon")
    local hasEnemyTag = model:FindFirstChild("Enemy") or model:FindFirstChild("Monster") or model:FindFirstChild("Aggro")
    
    local hasAttackScript = false
    for _, child in ipairs(model:GetDescendants()) do
        if child:IsA("Script") or child:IsA("LocalScript") then
            local name = child.Name:lower()
            if name:find("attack") or name:find("ai") or name:find("zombie") or name:find("kill") or name:find("combat") then
                hasAttackScript = true
                break
            end
        end
    end

    if hasWeapon or hasEnemyTag or hasAttackScript then
        return "Kẻ Địch", Color3.fromRGB(255, 50, 50)
    end

    return "Thân Thiện", Color3.fromRGB(0, 150, 255)
end

local function ApplyPlayerESP(player)
    if player == LocalPlayer then return end

    local function SetupPlayerChar(character)
        local hrp = character:WaitForChild("HumanoidRootPart", 10)
        if not hrp then return end

        if character:FindFirstChild("P_Highlight") then character["P_Highlight"]:Destroy() end
        if hrp:FindFirstChild("P_Gui") then hrp["P_Gui"]:Destroy() end

        local Highlight = Instance.new("Highlight")
        Highlight.Name = "P_Highlight"
        Highlight.FillTransparency = 1 
        Highlight.OutlineColor = Color3.fromRGB(255, 0, 0)
        Highlight.OutlineTransparency = 0
        Highlight.Adornee = character
        Highlight.Enabled = Player_Box_Enabled
        Highlight.Parent = character

        local BillboardGui = Instance.new("BillboardGui")
        BillboardGui.Name = "P_Gui"
        BillboardGui.Adornee = hrp
        BillboardGui.Size = UDim2.new(0, 200, 0, 50)
        BillboardGui.StudsOffset = Vector3.new(0, 3, 0)
        BillboardGui.AlwaysOnTop = true
        BillboardGui.Enabled = Player_Name_Enabled

        local TextLabel = Instance.new("TextLabel")
        TextLabel.Parent = BillboardGui
        TextLabel.BackgroundTransparency = 1
        TextLabel.Size = UDim2.new(1, 0, 1, 0)
        TextLabel.Text = player.Name
        TextLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        TextLabel.TextSize = 13
        TextLabel.Font = Enum.Font.SourceSansBold
        TextLabel.TextStrokeTransparency = 0

        BillboardGui.Parent = hrp
    end

    if player.Character then task.spawn(SetupPlayerChar, player.Character) end
    player.CharacterAdded:Connect(SetupPlayerChar)
end

local function ApplyNPC_ESP(model)
    local hrp = model:WaitForChild("HumanoidRootPart", 5)
    if not hrp then return end

    if model:FindFirstChild("NPC_Highlight") then model["NPC_Highlight"]:Destroy() end
    if hrp:FindFirstChild("NPC_Gui") then hrp["NPC_Gui"]:Destroy() end

    local npcType, npcColor = AnalyzeNPC(model)

    local Highlight = Instance.new("Highlight")
    Highlight.Name = "NPC_Highlight"
    Highlight.FillTransparency = 1 
    Highlight.OutlineColor = npcColor
    Highlight.OutlineTransparency = 0
    Highlight.Adornee = model
    Highlight.Enabled = NPC_Box_Enabled
    Highlight.Parent = model

    local BillboardGui = Instance.new("BillboardGui")
    BillboardGui.Name = "NPC_Gui"
    BillboardGui.Adornee = hrp
    BillboardGui.Size = UDim2.new(0, 200, 0, 50)
    BillboardGui.StudsOffset = Vector3.new(0, 3, 0)
    BillboardGui.AlwaysOnTop = true
    BillboardGui.Enabled = NPC_Name_Enabled

    local TextLabel = Instance.new("TextLabel")
    TextLabel.Parent = BillboardGui
    TextLabel.BackgroundTransparency = 1
    TextLabel.Size = UDim2.new(1, 0, 1, 0)
    TextLabel.Text = model.Name .. " [" .. npcType .. "]"
    TextLabel.TextColor3 = npcColor
    TextLabel.TextSize = 13
    TextLabel.Font = Enum.Font.SourceSansBold
    TextLabel.TextStrokeTransparency = 0

    BillboardGui.Parent = hrp
end

for _, p in ipairs(Players:GetPlayers()) do ApplyPlayerESP(p) end
