if _G.ThoDz_ESP_Executed then
    _G.ThoDz_Cleanup()
end
_G.ThoDz_Executed = true

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui", 15)

local Player_Box_Enabled = false
local Player_Name_Enabled = false
local NPC_Box_Enabled = false
local NPC_Name_Enabled = false
local Item_Box_Enabled = false
local Item_Name_Enabled = false

local ScreenGui, MainMenu, ToggleButton
local NPCCache = {}
local ItemCache = {}

local ValidItemKeywords = {"chest", "box", "crate", "fruit", "money", "coin", "cash", "gold", "diamond", "gem", "ore", "key", "loot", "pickup", "drop", "tool", "weapon", "potion"}
local IgnoreKeywords = {"npc", "shop", "dealer", "talk", "chat", "dialog", "sign", "board", "info", "quest", "portal", "accessory", "hat"}

local function IsNPC(model)
    if not model:IsA("Model") or Players:GetPlayerFromCharacter(model) then return false end
    return model:FindFirstChildOfClass("Humanoid") and model:FindFirstChild("HumanoidRootPart")
end

local function AnalyzeNPC(model)
    local humanoid = model:FindFirstChildOfClass("Humanoid")
    if not humanoid or humanoid.WalkSpeed <= 1 or model:FindFirstChild("ClickDetector") then return "Interaction", Color3.fromRGB(255, 255, 255) end
    if model:FindFirstChildOfClass("Tool") or model:FindFirstChild("Enemy") or model:FindFirstChild("Monster") then
        return "Enemy", Color3.fromRGB(255, 50, 50)
    end
    return "Friendly", Color3.fromRGB(0, 150, 255)
end

local function CheckObject(obj)
    if IsNPC(obj) then
        local npcType, npcColor = AnalyzeNPC(obj)
        NPCCache[obj] = {type = npcType, color = npcColor}
        return
    end

    if obj:IsA("BasePart") and obj.Parent and not obj.Parent:IsA("Accessory") then
        local nameLower = obj.Name:lower()
        local parentNameLower = obj.Parent.Name:lower()
        for _, ign in ipairs(IgnoreKeywords) do if nameLower:find(ign) or parentNameLower:find(ign) then return end end
        for _, kw in ipairs(ValidItemKeywords) do
            if nameLower:find(kw) or parentNameLower:find(kw) then
                ItemCache[obj] = true
                return
            end
        end
    end
end

local function FastMapScan()
    table.clear(NPCCache)
    table.clear(ItemCache)
    for _, obj in ipairs(workspace:GetDescendants()) do
        pcall(CheckObject, obj)
    end
end
FastMapScan()

local ScanTask = task.spawn(function()
    while true do
        task.wait(3)
        pcall(FastMapScan)
    end
end)

-- Hàm xóa sạch Highlight cũ khi tắt hoặc chuyển ván để tránh lỗi kẹt viền
local function ClearAllHighlights(hlName)
    for _, obj in ipairs(workspace:GetDescendants()) do
        local hl = obj:FindFirstChild(hlName)
        if hl then pcall(function() hl:Destroy() end) end
    end
end

local function BuildUI()
    if PlayerGui:FindFirstChild("Delta_Universal_ESP_ThoDz") then
        PlayerGui["Delta_Universal_ESP_ThoDz"]:Destroy()
    end

    ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "Delta_Universal_ESP_ThoDz"
    ScreenGui.ResetOnSpawn = false
    ScreenGui.Parent = PlayerGui

    ToggleButton = Instance.new("TextButton")
    ToggleButton.Parent = ScreenGui
    ToggleButton.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    ToggleButton.Position = UDim2.new(0.1, 0, 0.2, 0)
    ToggleButton.Size = UDim2.new(0, 55, 0, 55)
    ToggleButton.Text = "MENU"
    ToggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    ToggleButton.TextSize = 11
    ToggleButton.Font = Enum.Font.SourceSansBold

    local ButtonCorner = Instance.new("UICorner")
    ButtonCorner.CornerRadius = UDim.new(0, 12)
    ButtonCorner.Parent = ToggleButton

    local ButtonStroke = Instance.new("UIStroke")
    ButtonStroke.Color = Color3.fromRGB(0, 255, 150)
    ButtonStroke.Thickness = 1.5
    ButtonStroke.Parent = ToggleButton

    MainMenu = Instance.new("Frame")
    MainMenu.Parent = ScreenGui
    MainMenu.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    MainMenu.Position = UDim2.new(0.2, 0, 0.2, 0)
    MainMenu.Size = UDim2.new(0, 220, 0, 320)
    MainMenu.Visible = false

    local MenuCorner = Instance.new("UICorner")
    MenuCorner.CornerRadius = UDim.new(0, 8)
    MenuCorner.Parent = MainMenu

    local MenuTitle = Instance.new("TextLabel")
    MenuTitle.Parent = MainMenu
    MenuTitle.Size = UDim2.new(1, 0, 0, 35)
    MenuTitle.Text = "Thọ dz - Auto Refresh Fix"
    MenuTitle.TextColor3 = Color3.fromRGB(0, 255, 150)
    MenuTitle.TextSize = 16
    MenuTitle.Font = Enum.Font.SourceSansBold
    MenuTitle.BackgroundTransparency = 1

    local function CreateMenuToggle(text, pos, activeColor, hlName, callback)
        local btn = Instance.new("TextButton")
        btn.Parent = MainMenu
        btn.Size = UDim2.new(0, 180, 0, 30)
        btn.Position = pos
        btn.Font = Enum.Font.SourceSansBold
        btn.TextSize = 13
        
        local state = false
        local function updateText()
            btn.Text = text .. ": " .. (state and "BẬT" or "TẤT")
            btn.TextColor3 = state and activeColor or Color3.fromRGB(255, 100, 100)
        end
        
        updateText()
        btn.MouseButton1Click:Connect(function()
            state = not state
            updateText()
            if not state and hlName then
                ClearAllHighlights(hlName) -- Xóa sạch khi tắt đi bật lại
            end
            if state then
                FastMapScan() -- Quét ép buộc lại bản đồ ngay lập tức để nhận diện Object mới ván này
            end
            callback(state)
        end)
        
        local c = Instance.new("UICorner")
        c.CornerRadius = UDim.new(0, 5)
        c.Parent = btn
        btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    end

    CreateMenuToggle("Player Khung (Trắng)", UDim2.new(0, 20, 0, 45), Color3.fromRGB(255, 255, 255), "P_Highlight", function(v) Player_Box_Enabled = v end)
    CreateMenuToggle("Player Tên & Mét", UDim2.new(0, 20, 0, 85), Color3.fromRGB(255, 255, 255), "P_Gui", function(v) Player_Name_Enabled = v end)
    CreateMenuToggle("NPC Màu Người (Phân biệt)", UDim2.new(0, 20, 0, 135), Color3.fromRGB(255, 200, 0), "NPC_Highlight", function(v) NPC_Box_Enabled = v end)
    CreateMenuToggle("NPC Tên & Mét", UDim2.new(0, 20, 0, 175), Color3.fromRGB(255, 200, 0), "NPC_Gui", function(v) NPC_Name_Enabled = v end)
    CreateMenuToggle("Item Khung (Box)", UDim2.new(0, 20, 0, 225), Color3.fromRGB(255, 0, 255), "Item_Highlight", function(v) Item_Box_Enabled = v end)
    CreateMenuToggle("Item Tên & Mét", UDim2.new(0, 20, 0, 265), Color3.fromRGB(255, 0, 255), "Item_Gui", function(v) Item_Name_Enabled = v end)

    local function MakeDraggable(obj)
        local dragging, dragInput, dragStart, startPos
        obj.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                dragStart = input.Position
                startPos = obj.Position
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then dragging = false end
                end)
            end
        end)
        obj.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if input == dragInput and dragging then
                local delta = input.Position - dragStart
                obj.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            end
        end)
    end
    MakeDraggable(ToggleButton)
    MakeDraggable(MainMenu)

    ToggleButton.MouseButton1Click:Connect(function()
        MainMenu.Visible = not MainMenu.Visible
    end)
end

BuildUI()

local function UpdateHighlight(target, hlName, color, fillTrans, enabled)
    if not target or not target.Parent then return end
    local hl = target:FindFirstChild(hlName)
    if not hl and enabled then
        hl = Instance.new("Highlight")
        hl.Name = hlName
        hl.OutlineColor = Color3.fromRGB(255, 255, 255)
        hl.OutlineTransparency = 0.2
        hl.Parent = target
    end
    if hl then
        hl.Enabled = enabled
        if enabled then
            hl.FillColor = color
            hl.FillTransparency = fillTrans
            hl.Adornee = target
        end
    end
end

local function UpdateBillboard(hrp, guiName, text, color, enabled)
    if not hrp or not hrp.Parent then return end
    local gui = hrp:FindFirstChild(guiName)
    if not gui and enabled then
        gui = Instance.new("BillboardGui")
        gui.Name = guiName
        gui.Size = UDim2.new(0, 180, 0, 40)
        gui.StudsOffset = Vector3.new(0, 3, 0)
        gui.AlwaysOnTop = true
        
        local label = Instance.new("TextLabel")
        label.Parent = gui
        label.BackgroundTransparency = 1
        label.Size = UDim2.new(1, 0, 1, 0)
        label.TextSize = 13
        label.Font = Enum.Font.SourceSansBold
        label.TextStrokeTransparency = 0
        gui.Parent = hrp
    end
    if gui then
        gui.Enabled = enabled
        if enabled then
            gui.TextLabel.Text = text
            gui.TextLabel.TextColor3 = color
        end
    end
end

_G.ThoDz_Loop_Connection = RunService.Heartbeat:Connect(function()
    local character = LocalPlayer.Character
    local localHrp = character and character:FindFirstChild("HumanoidRootPart")
    
    if not ScreenGui or not ScreenGui.Parent then
        pcall(BuildUI)
    end

    -- 1. PLAYERS
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character.Parent then
            local char = player.Character
            local hrp = char:FindFirstChild("HumanoidRootPart")
            
            pcall(UpdateHighlight, char, "P_Highlight", Color3.fromRGB(255, 255, 255), 0.45, Player_Box_Enabled)
            if hrp and Player_Name_Enabled and localHrp then
                local dist = math.floor((hrp.Position - localHrp.Position).Magnitude)
                pcall(UpdateBillboard, hrp, "P_Gui", player.Name .. " [" .. dist .. "m]", Color3.fromRGB(255, 255, 255), true)
            elseif hrp then
                pcall(UpdateBillboard, hrp, "P_Gui", "", Color3.fromRGB(0,0,0), false)
            end
        end
    end

    -- 2. NPC
    for npc, data in pairs(NPCCache) do
        if npc and npc.Parent then
            local hrp = npc:FindFirstChild("HumanoidRootPart")
            pcall(UpdateHighlight, npc, "NPC_Highlight", data.color, 0.45, NPC_Box_Enabled)
            if hrp and NPC_Name_Enabled and localHrp then
                local dist = math.floor((hrp.Position - localHrp.Position).Magnitude)
                pcall(UpdateBillboard, hrp, "NPC_Gui", npc.Name .. " [" .. data.type .. "] [" .. dist .. "m]", data.color, true)
            elseif hrp then
                pcall(UpdateBillboard, hrp, "NPC_Gui", "", Color3.fromRGB(0,0,0), false)
            end
        else
            NPCCache[npc] = nil
        end
    end

    -- 3. ITEMS
    for item, _ in pairs(ItemCache) do
        if item and item.Parent then
            pcall(UpdateHighlight, item, "Item_Highlight", Color3.fromRGB(255, 0, 255), 0.5, Item_Box_Enabled)
            if Item_Name_Enabled and localHrp then
                local dist = math.floor((item.Position - localHrp.Position).Magnitude)
                pcall(UpdateBillboard, item, "Item_Gui", item.Name .. " [" .. dist .. "m]", Color3.fromRGB(255, 255, 0), true)
            else
                pcall(UpdateBillboard, item, "Item_Gui", "", Color3.fromRGB(0,0,0), false)
            end
        else
            ItemCache[item] = nil
        end
    end
end)

_G.ThoDz_Cleanup = function()
    if _G.ThoDz_Loop_Connection then _G.ThoDz_Loop_Connection:Disconnect() end
    if ScanTask then task.cancel(ScanTask) end
    if ScreenGui then ScreenGui:Destroy() end
    ClearAllHighlights("P_Highlight")
    ClearAllHighlights("NPC_Highlight")
    ClearAllHighlights("Item_Highlight")
    table.clear(NPCCache)
    table.clear(ItemCache)
end

